# Copy to .env and fill in values (never commit real secrets)
API_TOKEN=replace-with-your-api-token               # required for POST /run (Authorization: Bearer …)
ANTHROPIC_API_KEY=       # https://console.anthropic.com
OPENAI_API_KEY=          # https://platform.openai.com
GOOGLE_API_KEY=           # https://aistudio.google.com/apikey (Gemini cascade)
TAVILY_API_KEY=          # https://tavily.com
PINECONE_API_KEY=        # https://app.pinecone.io
PINECONE_INDEX=ai-agent         # index name — use dimension 1536 + metric cosine (not dotproduct) for text-embedding-3-small
DATABASE_URL=             # postgresql://agent:agent@postgres:5432/agent
REDIS_URL=                # redis://redis:6379/0
EXTERNAL_API_TOKEN=       # optional bearer for call_external_api
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=        # https://smith.langchain.com
LANGCHAIN_PROJECT=        # project name for LangSmith
